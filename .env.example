# Supabase Auth (required for login gate)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional allowlist controls (client-side enforcement)
# VITE_AUTH_ALLOWED_EMAILS=alice@company.com,bob@company.com
# VITE_AUTH_ALLOWED_DOMAIN=company.com

# Gemini API key (if you are using a project-wide key; note this is bundled client-side)
GEMINI_API_KEY=

# Optional: hide Visualizer (AI) from the sidebar by default
VITE_ENABLE_VISUALIZER=false
