# Supabase Auth (required for login gate)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional allowlist controls (client-side enforcement)
# VITE_AUTH_ALLOWED_EMAILS=alice@company.com,bob@company.com
# VITE_AUTH_ALLOWED_DOMAIN=company.com

# Optional: require Multi-Factor Auth (TOTP) after login + approval
VITE_AUTH_REQUIRE_MFA=false

# App environment label (used to separate "preview" vs "production" project lists when sharing a DB)
# - production: production URL data
# - preview: Vercel preview/development deployments (safe sandbox inside the same DB)
VITE_APP_ENV=production

# Optional error monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Optional support email used by "Report a problem"
VITE_SUPPORT_EMAIL=contact@sanluisai.com

# Gemini API key (if you are using a project-wide key; note this is bundled client-side)
GEMINI_API_KEY=

# Optional: hide Visualizer (AI) from the sidebar by default
VITE_ENABLE_VISUALIZER=false
